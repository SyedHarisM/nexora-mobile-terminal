{
  "expo": {
    "name": "nexora-app",
    "slug": "nexora-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nexoraapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#020105",
    "newArchEnabled": true,
    "ios": {
      "infoPlist": {
        "NSFaceIDUsageDescription": "Nexora needs FaceID to secure your digital presence.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true,
      "userInterfaceStyle": "dark",
      "bundleIdentifier": "com.nexora.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020105",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "edgeToEdgeEnabled": true,
      "statusBar": {
        "barStyle": "light-content",
        "translucent": true,
        "backgroundColor": "#00000000"
      },
      "navigationBar": {
        "barStyle": "light-content",
        "backgroundColor": "#00000000"
      },
      "package": "com.anonymous.nexoraapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Nexora needs FaceID to secure your digital presence."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020105"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f6a2f44d-314c-44f9-ab8a-03c4093a4ff0"
      }
    }
  }
}
